# ============================================================================
# Doorstep Hub — Voice Stream Server (VPS)
# Handles Exotel Voicebot bidirectional WebSocket: STT -> Gemini -> TTS
# ============================================================================

# HTTP/WS listen port (behind Apache/Nginx reverse proxy for wss://voice.doorstephub.com)
PORT=5014

# Public path the reverse proxy forwards the WebSocket to
WS_PATH=/stream

# Toggle the whole streaming server behaviour
AI_VOICE_STREAM_ENABLED=true

# ----------------------------------------------------------------------------
# MongoDB — MUST be the SAME database as the main cPanel backend so sessions
# and messages show up in the admin panel.
# ----------------------------------------------------------------------------
MONGO_URI=mongodb+srv://user:pass@cluster/dbname

# ----------------------------------------------------------------------------
# Audio — keep sample rate consistent with the ?sample-rate= query on the
# Exotel Voicebot applet / streamurl. 16000 recommended.
# ----------------------------------------------------------------------------
AUDIO_SAMPLE_RATE=16000

# ----------------------------------------------------------------------------
# Google Cloud STT + TTS
# Streaming STT needs a SERVICE ACCOUNT (API keys don't work for gRPC streaming).
# Create a service account on project 970716539757 with:
#   - Cloud Speech-to-Text API
#   - Cloud Text-to-Speech API
# Download JSON and point GOOGLE_APPLICATION_CREDENTIALS at it.
# ----------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
GCP_PROJECT_ID=970716539757

STT_LANGUAGE=en-IN
TTS_LANGUAGE=en-IN
TTS_VOICE=en-IN-Neural2-A

# Multi-language: caller can code-switch. STT listens for the session language
# plus these (max 3) alternates. Set STT_AUTO_DETECT=false to lock to one lang.
STT_AUTO_DETECT=true
STT_ALTERNATIVE_LANGUAGES=en-IN,hi-IN

# Premium Chirp3-HD voice speaker used for every language (warm female = Diya).
# Options incl: Kore, Aoede, Leda (female), Charon, Puck (male).
TTS_CHIRP_VOICE=Kore
# Optional per-language voice overrides (full voice name). Leave unset to use
# the Chirp3-HD voice above; falls back to Standard/Neural2 automatically.
# TTS_VOICE_EN=en-IN-Chirp3-HD-Kore
# TTS_VOICE_HI=hi-IN-Chirp3-HD-Kore
# TTS_VOICE_TE=te-IN-Chirp3-HD-Kore
# TTS_VOICE_KN=kn-IN-Chirp3-HD-Kore
# TTS_VOICE_TA=ta-IN-Chirp3-HD-Kore

# ----------------------------------------------------------------------------
# Gemini (AI Studio AQ. key via @google/genai)
# ----------------------------------------------------------------------------
AI_API_KEY=AQ.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=gemini-2.0-flash

# ----------------------------------------------------------------------------
# Security — Exotel IP whitelist (comma separated). Email hello@exotel.com
# for their current IP ranges. Leave blank to allow all (NOT recommended).
# ----------------------------------------------------------------------------
ALLOWED_IPS=

# Optional Basic auth on the WSS endpoint (matches Exotel applet auth config)
WS_BASIC_AUTH_USER=
WS_BASIC_AUTH_PASS=

# ----------------------------------------------------------------------------
# Actions — the AI calls back to the cPanel backend to take real actions
# (send payment link, WhatsApp message, callback, escalation) during a call.
# AI_VOICE_INTERNAL_TOKEN must MATCH the same value in the cPanel .env.
# ----------------------------------------------------------------------------
BACKEND_ACTIONS_URL=https://api.doorstephub.com/v1/dhubApi/web/ai-voice/actions
AI_VOICE_INTERNAL_TOKEN=

# Conversation limits
MAX_CALL_SECONDS=600
SILENCE_TIMEOUT_MS=8000
